<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.TextFlow?>
<?import javafx.scene.text.Text?>

<VBox alignment="TOP_CENTER"
      spacing="16"
      styleClass="root"
      stylesheets="@../../../css/styles.css"
      xmlns="http://javafx.com/javafx/23"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="cs151.application.controller.DefineFlashcardController">

    <padding>
        <Insets bottom="20" left="30" right="30" top="10" />
    </padding>

    <!-- Top bar -->
    <ButtonBar prefHeight="40">
        <buttons>
            <Button onAction="#goBackHomeOp"
                    styleClass="back-btn"
                    text="⌂ Back to Home" />
        </buttons>
    </ButtonBar>

    <!-- Title -->
    <Label text="Add Flashcard" styleClass="title-label" />

    <!-- Form card — grows to fill available vertical space -->
    <VBox id="form-card"
          VBox.vgrow="ALWAYS"
          fillWidth="true"
          maxWidth="Infinity">
        <padding>
            <Insets bottom="20" left="20" right="20" top="20" />
        </padding>

        <!-- Deck selection -->
        <Label styleClass="field-labels" text="Deck *" />
        <ComboBox fx:id="deckComboBox"
                  promptText="Select a deck…"
                  maxWidth="Infinity" />
        <Label fx:id="deckErrorLabel" styleClass="error-labels" />

        <!-- Deck description — hidden until a deck is selected -->
        <VBox fx:id="deckDescriptionBox"
              spacing="4"
              managed="false"
              visible="false"
              fillWidth="true">
            <Label styleClass="field-labels-sub" text="Description" />
            <TextFlow styleClass="deck-description" maxWidth="Infinity">
                <Text fx:id="deckDescriptionText" />
            </TextFlow>
        </VBox>

        <!-- Front Text — expands and contracts with window height -->
        <Label styleClass="field-labels" text="Front Text *" />
        <TextArea fx:id="frontTextArea"
                  promptText="Enter the question or term…"
                  wrapText="true"
                  minHeight="60"
                  VBox.vgrow="ALWAYS" />
        <Label fx:id="frontErrorLabel" styleClass="error-labels" />

        <!-- Back Text — expands and contracts with window height -->
        <Label styleClass="field-labels" text="Back Text *" />
        <TextArea fx:id="backTextArea"
                  promptText="Enter the answer or definition…"
                  wrapText="true"
                  minHeight="60"
                  VBox.vgrow="ALWAYS" />
        <Label fx:id="backErrorLabel" styleClass="error-labels" />

        <!-- Status -->
        <Label text="Status *" styleClass="field-labels" />
        <ComboBox fx:id="statusComboBox"
                  promptText="Select status"
                  prefWidth="200" />
        <Label fx:id="statusErrorLabel" styleClass="error-labels" />

    </VBox>

    <!-- Action buttons -->
    <HBox spacing="10" alignment="CENTER_RIGHT" maxWidth="Infinity">
        <Button onAction="#onClearFields"
                text="Clear"
                prefWidth="90" />
        <Button onAction="#onSaveFlashcard"
                text="Save Flashcard"
                styleClass="primary-btn"
                prefWidth="140" />
    </HBox>

    <!-- Success message -->
    <Label fx:id="successLabel" />

</VBox>