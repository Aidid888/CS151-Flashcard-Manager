<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>

   <BorderPane prefHeight="500.0"
               prefWidth="600.0"
               styleClass="root"
               stylesheets="@../../../css/styles.css"
               xmlns="http://javafx.com/javafx/23"
               xmlns:fx="http://javafx.com/fxml/1"
               fx:controller="cs151.application.controller.DefineDeckController">

       <padding>
           <Insets bottom="20" left="20" right="20" top="20" />
       </padding>

        <top>
            <HBox prefHeight="51.0" prefWidth="362.0" BorderPane.alignment="CENTER">
                <children>
                    <Label prefHeight="22.0" prefWidth="495.0" styleClass="title-label" text="Create Flashcard Deck" textAlignment="JUSTIFY">
                        <HBox.margin>
                            <Insets bottom="50.0" top="10.0" />
                        </HBox.margin>
                    </Label>
                    <ToolBar prefHeight="40.0" prefWidth="167.0">
                        <items>
                            <Button onAction="#onExitButtonClickOp" styleClass="back-btn" text="⌂ Back to Home" />
                        </items>
                    </ToolBar>
                </children>
            </HBox>
        </top>

    <center>
         <Pane prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
            <children>
               <Pane styleClass="pane-layer" layoutX="100.0" layoutY="-3.0" prefHeight="207.0" prefWidth="360.0">
                  <children>
                     <Pane styleClass="pane-layer" layoutX="-8.0" layoutY="-13.0" prefHeight="207.0" prefWidth="360.0">
                        <effect>
                           <DropShadow height="29.76" offsetX="5.0" offsetY="5.0" radius="15.594999999999999" width="34.62">
                              <color>
                                 <Color red="0.41999998688697815" green="0.3779999911785126" blue="0.3779999911785126" opacity="0.6116752028465271" />
                              </color>
                           </DropShadow>
                        </effect>
                        <children>
                           <VBox layoutX="26.0" layoutY="14.0" prefHeight="179.0" prefWidth="309.0">
                              <children>
                                  <TextField fx:id="deckNameField" promptText="Deck Name (required)" />
                                  <TextArea fx:id="descriptionField" prefHeight="168.0" prefWidth="292.0" promptText="Description (optional)" />
                              </children>
                           </VBox>
                        </children>
                     </Pane>
                  </children>
                  <effect>
                     <DropShadow height="29.76" offsetX="5.0" offsetY="5.0" radius="15.594999999999999" width="34.62">
                        <color>
                           <Color red="0.41999998688697815" green="0.3779999911785126" blue="0.3779999911785126" opacity="0.6116752028465271" />
                        </color>
                     </DropShadow>
                  </effect>
               </Pane>
            </children>
         </Pane>
      </center>

        <bottom>
            <VBox alignment="center" prefHeight="55.0" prefWidth="260.0" BorderPane.alignment="CENTER">
                <children>
                    <Button fx:id="createDeckBtn" text="➕ Create Deck" onAction="#createDeckOp" alignment="CENTER"/>
                    <Label fx:id="promptMsgLbl" styleClass="prompt-label" text="please provide the Deck a new name first" alignment="CENTER"/>
                </children>
            </VBox>
        </bottom>

    </BorderPane>

