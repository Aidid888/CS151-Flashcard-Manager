<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER"
      spacing="14"
      styleClass="root"
      stylesheets="@../../../css/styles.css"
      xmlns="http://javafx.com/javafx/23"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="cs151.application.controller.ReportController">

    <padding>
        <Insets bottom="24" left="28" right="28" top="18" />
    </padding>

    <!-- Top bar -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Button onAction="#goBackHomeOp" styleClass="back-btn" text="⌂ Back to Home" />
        <Region HBox.hgrow="ALWAYS" />
        <Label styleClass="title-label" text="Reports" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <!--
        ════════════════════════════════
         Four tabs matching the four
         report requirements in §2.1.3
        ════════════════════════════════
    -->
    <TabPane fx:id="reportTabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

        <!-- ═══════════════════════════════════════════════
             Tab 1 — Deck Overview
             List of all Decks with total Flashcard count.
             ═══════════════════════════════════════════════ -->
        <Tab text="Deck Overview">
            <VBox spacing="10">
                <padding><Insets bottom="16" left="4" right="4" top="14" /></padding>

                <Label styleClass="field-label" text="ALL DECKS" />

                <TableView fx:id="deckOverviewTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="deckNameCol"      text="Deck Name"   prefWidth="200" />
                        <TableColumn fx:id="deckDescCol"      text="Description" prefWidth="320" />
                        <TableColumn fx:id="deckCardCountCol" text="Cards"       prefWidth="80"  />
                    </columns>
                    <placeholder>
                        <Label text="No decks found." styleClass="field-label" />
                    </placeholder>
                </TableView>
            </VBox>
        </Tab>

        <!-- ═══════════════════════════════════════════════
             Tab 2 — By Status
             Counts of New / Learning / Mastered across
             all flashcards.
             ═══════════════════════════════════════════════ -->
        <Tab text="By Status">
            <VBox spacing="20" alignment="TOP_CENTER">
                <padding><Insets bottom="24" left="24" right="24" top="24" /></padding>

                <Label styleClass="field-label" text="FLASHCARD STATUS BREAKDOWN" />

                <!-- Stat cards row -->
                <HBox spacing="20" alignment="CENTER">

                    <VBox styleClass="stat-card" alignment="CENTER" spacing="6" HBox.hgrow="ALWAYS">
                        <Label fx:id="newCountLabel" styleClass="stat-value, new-accent" text="—" />
                        <Label styleClass="stat-label-text" text="New" />
                    </VBox>

                    <VBox styleClass="stat-card" alignment="CENTER" spacing="6" HBox.hgrow="ALWAYS">
                        <Label fx:id="learningCountLabel" styleClass="stat-value, learning-accent" text="—" />
                        <Label styleClass="stat-label-text" text="Learning" />
                    </VBox>

                    <VBox styleClass="stat-card" alignment="CENTER" spacing="6" HBox.hgrow="ALWAYS">
                        <Label fx:id="masteredCountLabel" styleClass="stat-value, mastered-accent" text="—" />
                        <Label styleClass="stat-label-text" text="Mastered" />
                    </VBox>

                </HBox>
            </VBox>
        </Tab>

        <!-- ═══════════════════════════════════════════════
             Tab 3 — Deck Detail
             Select a deck → see all its Flashcards in a
             TableView (JavaFX TableView, per spec §2.1.3.3).
             ═══════════════════════════════════════════════ -->
        <Tab text="Deck Detail">
            <VBox spacing="10">
                <padding><Insets bottom="16" left="4" right="4" top="14" /></padding>

<!--                <HBox spacing="12" alignment="CENTER_LEFT">-->
<!--                    <Label styleClass="field-label" text="SELECT DECK:" />-->
<!--                    <ComboBox fx:id="deckDetailComboBox"-->
<!--                              onAction="#onDeckDetailSelected"-->
<!--                              prefWidth="240"-->
<!--                              promptText="— choose a deck —" />-->
<!--                    <Label fx:id="deckDetailCountLabel"-->
<!--                           styleClass="card-count-label" text="" />-->
<!--                </HBox>-->

                <TableView fx:id="flashcardDetailTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="fcFrontCol"      text="Front"         prefWidth="200" />
                        <TableColumn fx:id="fcBackCol"       text="Back"          prefWidth="200" />
                        <TableColumn fx:id="fcStatusCol"     text="Status"        prefWidth="100" />
                        <TableColumn fx:id="fcCreatedCol"    text="Created"       prefWidth="110" />
                        <TableColumn fx:id="fcLastReviewCol" text="Last Reviewed" prefWidth="120" />
                    </columns>
                    <placeholder>
                        <Label text="Select a deck above to view its flashcards."
                               styleClass="field-label" />
                    </placeholder>
                </TableView>
            </VBox>
        </Tab>

        <!-- ═══════════════════════════════════════════════
             Tab 4 — Overall Summary
             Total Decks, Total Flashcards, % Mastered.
             ═══════════════════════════════════════════════ -->
        <Tab text="Summary">
            <VBox spacing="20" alignment="TOP_CENTER">
                <padding><Insets bottom="24" left="24" right="24" top="24" /></padding>

                <Label styleClass="field-label" text="OVERALL SUMMARY" />

                <HBox spacing="20" alignment="CENTER">

                    <VBox styleClass="stat-card" alignment="CENTER" spacing="6" HBox.hgrow="ALWAYS">
                        <Label fx:id="totalDecksLabel" styleClass="stat-value" text="—" />
                        <Label styleClass="stat-label-text" text="Total Decks" />
                    </VBox>

                    <VBox styleClass="stat-card" alignment="CENTER" spacing="6" HBox.hgrow="ALWAYS">
                        <Label fx:id="totalCardsLabel" styleClass="stat-value" text="—" />
                        <Label styleClass="stat-label-text" text="Total Flashcards" />
                    </VBox>

                    <VBox styleClass="stat-card" alignment="CENTER" spacing="6" HBox.hgrow="ALWAYS">
                        <Label fx:id="masteredPctLabel" styleClass="stat-value, mastered-accent" text="—" />
                        <Label styleClass="stat-label-text" text="Mastered" />
                    </VBox>

                </HBox>

            </VBox>
        </Tab>

    </TabPane>

</VBox>
