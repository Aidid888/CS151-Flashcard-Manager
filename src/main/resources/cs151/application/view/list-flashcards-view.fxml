<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER"
      spacing="10"
      styleClass="root"
      stylesheets="@../../../css/styles.css"
      xmlns="http://javafx.com/javafx/23"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="cs151.application.controller.ListFlashcardController">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <!-- Back to Home button -->
    <ButtonBar prefHeight="40">
        <buttons>
            <Button onAction="#goBackHomeOp"
                    styleClass="back-btn"
                    text="⌂ Back to Home" />
        </buttons>
    </ButtonBar>

    <!-- Title -->
    <Label styleClass="title-label"
           text="All Flashcards" />

    <!-- Deck filter -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Filter by Deck:" />
        <ComboBox fx:id="deckComboBox"
                  onAction="#onDeckSelected"
                  prefWidth="220"
                  promptText="Select a deck…" />
    </HBox>

    <!-- TableView for list of Flashcards in chosen Deck -->
    <TableView fx:id="flashcardTable" prefWidth="900">
        <columns>
            <TableColumn fx:id="deckNameColumn"     prefWidth="150" text="Deck" />
            <TableColumn fx:id="frontTextColumn"    prefWidth="200" text="Front Text" />
            <TableColumn fx:id="backTextColumn"     prefWidth="200" text="Back Text" />
            <TableColumn fx:id="statusColumn"       prefWidth="100" text="Status" />
            <TableColumn fx:id="creationDateColumn" prefWidth="160" text="Created" />
            <TableColumn fx:id="lastViewedColumn"   prefWidth="160" text="Last Reviewed" />
            <TableColumn fx:id="deleteColumn"       prefWidth="80"  text="Action" />
        </columns>
    </TableView>

</VBox>