<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER"
      spacing="15"
      styleClass="root"
      stylesheets="@../../../css/styles.css"
      xmlns="http://javafx.com/javafx/23"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="cs151.application.controller.DeckReviewController">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <!-- Back to Home button -->
    <ButtonBar prefHeight="40.0" prefWidth="200.0">
        <buttons>
            <Button onAction="#goBackHomeOp" styleClass="back-btn" text="⌂ Back to Home" />
        </buttons>
    </ButtonBar>

    <!-- Title -->
    <Label styleClass="title-label" text="Review Flashcards" />

    <!-- Deck Information Section -->
    <VBox spacing="5" style="-fx-background-color: derive(-fx-base, 5%); -fx-padding: 10; -fx-background-radius: 5;">
        <Label text="Deck:" style="-fx-font-weight: bold;" />
        <TextField fx:id="deckNameField" />
    </VBox>

    <!-- Filter Section -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Filter:" style="-fx-font-weight: bold;" />
        <ComboBox fx:id="filterComboBox" onAction="#onFilterChanged" prefWidth="150" />
        <Label fx:id="cardCountLabel" text="0 / 0" style="-fx-font-style: italic; -fx-text-fill: gray;" />
    </HBox>

    <!-- Flashcard Content Section -->
    <VBox spacing="10" VBox.vgrow="ALWAYS">

        <!-- Front Text -->
        <VBox spacing="5">
            <Label text="Front:" style="-fx-font-weight: bold;" />
            <TextArea fx:id="frontTextArea" prefHeight="100" wrapText="true" />
        </VBox>

        <!-- Back Text -->
        <VBox spacing="5">
            <Label text="Back:" style="-fx-font-weight: bold;" />
            <TextArea fx:id="backTextArea" prefHeight="100" wrapText="true" />
        </VBox>

        <!-- Status -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Status:" style="-fx-font-weight: bold;" minWidth="100" />
            <ComboBox fx:id="statusComboBox" prefWidth="150" />
        </HBox>

        <!-- Read-only fields: Creation Date and Last Reviewed -->
        <HBox spacing="20">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Creation Date:" style="-fx-font-weight: bold;" />
                <TextField fx:id="creationDateField" />
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Last Reviewed:" style="-fx-font-weight: bold;" />
                <TextField fx:id="lastReviewedField" />
            </VBox>
        </HBox>

    </VBox>

    <!-- Status Label -->
    <Label fx:id="statusLabel" style="-fx-text-fill: green; -fx-font-weight: bold;" />

    <!-- Navigation and Action Buttons -->
    <HBox spacing="10" alignment="CENTER">
        <Button fx:id="previousBtn" text="← Previous" onAction="#onPrevious" prefWidth="100" />
        <Button fx:id="nextBtn" text="Next →" onAction="#onNext" prefWidth="100" />
        <Button fx:id="saveBtn" text="Save" onAction="#onSave" prefWidth="100" styleClass="primary-btn" />
        <Button text="Back" onAction="#onCancel" prefWidth="100" />
    </HBox>

</VBox>
