<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER"
      spacing="14"
      styleClass="root"
      stylesheets="@../../../css/styles.css"
      xmlns="http://javafx.com/javafx/23"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="cs151.application.controller.DeckReviewController">

    <padding>
        <Insets bottom="24" left="28" right="28" top="18" />
    </padding>

    <!-- Top nav bar: back button left, deck name right -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Button onAction="#goBackHomeOp" styleClass="back-btn" text="⌂ Back to Home" />
        <Region HBox.hgrow="ALWAYS" />
        <Label styleClass="deck-title-label" text="Deck Name:" />
        <Label fx:id="deckNameLabel" styleClass="deck-title-label" text="Deck" />
    </HBox>

    <!-- Filter row -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label styleClass="field-label" text=" Status Filter:" />
        <ComboBox fx:id="filterComboBox" onAction="#onFilterChanged" prefWidth="140" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="cardCountLabel" styleClass="card-count-label" text="— / —" />
    </HBox>

    <!--
        ════════════════════════════════
         FLIP CARD — the core widget frontFace and backFace share the
         same StackPane cell; only one is visible at a time.
        ════════════════════════════════
    -->
    <StackPane fx:id="cardStackPane" styleClass="flash-card" VBox.vgrow="ALWAYS">

        <!-- FRONT FACE -->
        <VBox fx:id="frontFace" styleClass="card-face" alignment="TOP_LEFT" spacing="8">
            <padding><Insets bottom="18" left="22" right="22" top="16" /></padding>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label styleClass="face-badge, front-badge" text="FRONT" />
                <Region HBox.hgrow="ALWAYS" />
            </HBox>
            <TextArea fx:id="frontTextArea"
                      styleClass="card-textarea"
                      wrapText="true"
                      VBox.vgrow="ALWAYS" />
        </VBox>

        <!-- BACK FACE (hidden by default) -->
        <VBox fx:id="backFace" styleClass="card-face" alignment="TOP_LEFT" spacing="8"
              visible="false" managed="false">
            <padding><Insets bottom="18" left="22" right="22" top="16" /></padding>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label styleClass="face-badge, back-badge" text="BACK" />
                <Region HBox.hgrow="ALWAYS" />
            </HBox>
            <TextArea fx:id="backTextArea"
                      styleClass="card-textarea"
                      wrapText="true"
                      VBox.vgrow="ALWAYS" />
        </VBox>

    </StackPane>

    <!-- Status / Date meta row -->
    <HBox alignment="CENTER_LEFT" spacing="20">

        <VBox spacing="3">
            <Label styleClass="field-label" text="Status" />
            <ComboBox fx:id="statusComboBox" prefWidth="140" />
        </VBox>

        <Region HBox.hgrow="ALWAYS" />

        <VBox spacing="3" alignment="CENTER_RIGHT">
            <Label styleClass="field-label" text="Created" />
            <TextField fx:id="creationDateField" styleClass="date-field" editable="false" prefWidth="130" />
        </VBox>

        <VBox spacing="3" alignment="CENTER_RIGHT">
            <Label styleClass="field-label" text="Last Reviewed" />
            <TextField fx:id="lastReviewedField" styleClass="date-field" editable="false" prefWidth="130" />
        </VBox>

    </HBox>

    <!-- Feedback / status message -->
    <Label fx:id="statusLabel" styleClass="status-feedback-label" />

    <!-- Navigation + action buttons -->
    <HBox alignment="CENTER" spacing="10">
        <Button fx:id="previousBtn" onAction="#onPrevious"
                styleClass="nav-btn" text="← Prev" prefWidth="90" />
        <Button fx:id="nextBtn" onAction="#onNext"
                styleClass="nav-btn" text="Next →" prefWidth="90" />
        <Button fx:id="flipBtn" onAction="#flipCard"
                styleClass="flip-btn" text="↻ Flip" prefWidth="90" />
        <Button fx:id="saveBtn" onAction="#onSave"
                styleClass="primary-btn" text="Save" prefWidth="90" />
        <Button onAction="#onCancel"
                styleClass="secondary-btn" text="Cancel / Back to Deck List" prefWidth="200" />
    </HBox>

</VBox>
